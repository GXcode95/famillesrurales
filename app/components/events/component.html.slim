article.px-4.py-2.border.border-gray-200.shadow-lg.relative
  .text-xs.text-gray-500.absolute.top-2.left-4
    - if @event.date.present?
      = l(@event.date, format: :short)
    - else
      = l(@event.updated_at, format: :short)

  - if @editable
    .absolute.top-2.right-2.flex.flex-row.gap-2
      = link_to "Modifier", edit_event_path(@event), class: "inline-flex items-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700"
      = button_to "Supprimer", @event, method: :delete, data: { confirm: "Supprimer cet événement ?" }, class: "inline-flex items-center rounded-md border border-transparent bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700"

  header.pt-2.sm:pt-4
    h1.text-3xl.sm:text-4xl.lg:text-5xl.font-bold.text-black.mb-4.leading-tight.uppercase.tracking-wide
      - if @link_to_show
        = link_to @event.name, @event, class: "hover:underline"
      - else
        = @event.name

  .px-6
    - if @event.body.present?
      .text-gray-800.leading-relaxed.text-base.sm:text-lg.whitespace-pre-line
        = @event.body

    - if @event.gallery_photos.any?
      .mt-4.columns-2.sm:columns-3.lg:columns-4.gap-1
        - @event.gallery_photos.each do |gp|
          - next unless gp.image.attached?
          article.break-inside-avoid.mb-1
            = link_to url_for(gp.image.variant(resize_to_limit: [1600, 1600])), target: "_blank", rel: "noopener", class: "block overflow-hidden bg-gray-100"
              = image_tag gp.image.variant(resize_to_limit: [900, 900]),
                class: "w-full h-auto align-middle object-cover block",
                alt: "",
                loading: "lazy"

    - if @show_comments
      .mt-4.pt-4.border-t.border-gray-200
        h3.text-sm.font-semibold.text-gray-900.mb-2
          | Commentaires
        - comments = @event.comments.order(created_at: :asc)
        - if comments.any?
          ul.space-y-2.mb-4
            - comments.each do |c|
              li.text-sm.text-gray-700.space-y-1
                .flex.items-center.justify-between
                  span.font-medium
                    = c.author.presence || "Anonyme"
                    - if @signed_in && c.email.present?
                      span.text-gray-500.text-xs.ml-2
                        | (
                        = c.email
                        | )
                  - if @signed_in
                    = button_to "Supprimer", event_comment_path(@event, c), method: :delete, data: { confirm: "Supprimer ce commentaire ?" }, class: "inline-flex rounded-md border border-transparent bg-red-600 px-2 py-0.5 text-xs font-medium text-white hover:bg-red-700"
                p.text-gray-700.whitespace-pre-line
                  = c.content
        - else
          p.text-sm.text-gray-500.mb-4
            | Aucun commentaire pour le moment.
        .pt-2
          = helpers.simple_form_for([@event, comment], url: event_comments_path(@event)) do |f|
            = f.error_notification
            .space-y-2
              = f.input :author, label: "Pseudo", required: true
              = f.input :email, label: "Email (optionnel)", required: false
              = f.input :content, label: "Commentaire", as: :text
            .mt-2
              = f.button :submit, "Publier", class: "inline-flex items-center rounded-md border border-transparent bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700"
